# Copy this file to .env and fill in your values.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Supported providers: gemini, local
# "local" uses an extractive summariser with no API calls.
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini. Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key

# Model name for the chosen provider.
# gemini example: gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Embeddings ───────────────────────────────────────────────────────────────
# Supported providers: fastembed
EMBEDDING_PROVIDER=fastembed

# FastEmbed model to use (runs locally via ONNX, no API key needed).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Fintech Classifier ───────────────────────────────────────────────────────
# RSS entries are filtered by a chat model (title + description) so only fintech
# articles are kept.
# Provider: "ollama" (local, default) or "huggingface" (hosted).
CLASSIFIER_PROVIDER=ollama

# Model to run. Defaults: "qwen2.5:7b" (ollama) / "Qwen/Qwen2.5-7B-Instruct" (hf).
# Pick one for your hardware, e.g. ollama: qwen2.5:3b, llama3.2:3b, qwen2.5:14b.
# CLASSIFIER_MODEL=qwen2.5:7b

# For CLASSIFIER_PROVIDER=ollama: run Ollama locally and pull your chosen model
# (e.g. `ollama pull qwen2.5:7b`). Override the server URL if not on default port.
OLLAMA_BASE_URL=http://localhost:11434

# For CLASSIFIER_PROVIDER=huggingface: a Hugging Face token with Inference access.
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=your-hugging-face-token

# ── Vector Store ─────────────────────────────────────────────────────────────
# Supported providers: faiss (in-memory), supabase (persistent pgvector)
# Omit or set to "faiss" to skip Supabase setup entirely.
VECTORSTORE_PROVIDER=supabase

# ── Supabase (required when VECTORSTORE_PROVIDER=supabase) ───────────────────
# Project URL from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — grants write access for upserts.
# Found at: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MMR (Maximal Marginal Relevance) retrieval config
# Number of chunks passed to the LLM (default: 5)
RETRIEVAL_K=5
# Candidate pool MMR selects from; must be >= RETRIEVAL_K (default: 20)
RETRIEVAL_FETCH_K=20
# Relevance/diversity dial: 1.0 = pure relevance, 0.0 = pure diversity (default: 0.5)
RETRIEVAL_LAMBDA_MULT=0.5

# ── Observability — Langfuse (optional) ──────────────────────────────────────
# Leave blank to disable tracing. Sign up at https://langfuse.com/
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── AI Gateway ───────────────────────────────────────────────────────────────
# Controls cost optimisation, caching, and spend limits.
# All keys below are optional — defaults shown are applied if omitted.

# Enable/disable the gateway entirely (default: true)
AI_GATEWAY_ENABLED=true

# Routing strategy: cost_optimized | quality_first | hybrid (default: hybrid)
AI_GATEWAY_STRATEGY=hybrid

# Cache LLM responses to avoid redundant API calls (default: true)
AI_GATEWAY_CACHE_ENABLED=true

# Cache backend: memory (in-process) | sqlite (persists across restarts)
AI_GATEWAY_CACHE_TYPE=memory

# How long to keep cached responses in seconds (default: 604800 = 7 days)
AI_GATEWAY_CACHE_TTL_SECONDS=604800

# Hard spend limits — app will stop calling the LLM if exceeded
AI_GATEWAY_COST_LIMIT_DAILY=5.0
AI_GATEWAY_COST_LIMIT_MONTHLY=100.0

# Emit per-call cost metrics to logs (default: true)
AI_GATEWAY_TRACK_METRICS=true
