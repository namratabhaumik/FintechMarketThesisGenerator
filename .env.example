# Copy this file to .env and fill in your values.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Supported providers: gemini, local
# "local" uses an extractive summariser with no API calls.
# Note: this only sets the primary model. If AI_GATEWAY_ENABLED=true (default),
# the gateway's AI_GATEWAY_STRATEGY can still route individual calls to the
# local fallback (large documents, daily spend limit reached) even when
# LLM_PROVIDER=gemini and it's healthy. Use AI_GATEWAY_STRATEGY=quality_first
# to always use the primary model.
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini. Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key

# Model name for the chosen provider.
# gemini example: gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Embeddings ───────────────────────────────────────────────────────────────
# Supported providers: fastembed
EMBEDDING_PROVIDER=fastembed

# FastEmbed model to use (runs locally via ONNX, no API key needed).
EMBEDDING_MODEL=jinaai/jina-embeddings-v2-small-en

# Where FastEmbed caches its ONNX model. Defaults to the HuggingFace cache dir
# (persistent; also what the daily-ingest workflow caches). Leave unset unless
# you want a different location. (The library's own default is the OS temp dir,
# which macOS purges - causing a recurring re-download.)
# FASTEMBED_CACHE_DIR=~/.cache/huggingface

# ── Fintech Classifier ───────────────────────────────────────────────────────
# RSS entries are filtered by a chat model (title + description) so only fintech
# articles are kept.
# Provider: "ollama" (local, default) or "huggingface" (hosted).
CLASSIFIER_PROVIDER=ollama

# Model to run. Defaults: "qwen2.5:7b" (ollama) / "Qwen/Qwen2.5-7B-Instruct" (hf).
# Pick one for your hardware, e.g. ollama: qwen2.5:3b, llama3.2:3b, qwen2.5:14b.
# CLASSIFIER_MODEL=qwen2.5:7b

# For CLASSIFIER_PROVIDER=ollama: run Ollama locally and pull your chosen model
# (e.g. `ollama pull qwen2.5:7b`). Override the server URL if not on default port.
OLLAMA_BASE_URL=http://localhost:11434

# For CLASSIFIER_PROVIDER=huggingface: a Hugging Face token with Inference access.
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=your-hugging-face-token

# ── Vector Store ─────────────────────────────────────────────────────────────
# Vector store: Supabase (persistent pgvector)
VECTORSTORE_PROVIDER=supabase

# ── Supabase (required when VECTORSTORE_PROVIDER=supabase) ───────────────────
# Project URL from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — grants write access for upserts.
# Found at: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRhYmpxcnl1YmFkeGlsZ2tkbXZ6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU0MTczNDEsImV4cCI6MjA5MDk5MzM0MX0.G_aPZx2sYSF11-gd9Dv-oPkUxuzSk-TdYq5_xenfe2Q

# ── API / CORS ───────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Interactive API docs (Swagger /docs, ReDoc /redoc, /openapi.json) on for local + dev.
ENABLE_DOCS=true

# ── API security (rate limits; all optional) ─────────────────────────────────
# Auth is per-user via Supabase JWTs (see SUPABASE_ANON_KEY above); there is no
# shared API key. The knobs below are only rate limiting.

# Per-IP rate limits on the two LLM endpoints (slowapi "N/period" syntax).
# RATE_LIMIT_GENERATE=10/minute
# RATE_LIMIT_REFINE=20/minute

# Optional global ceiling across ALL routes (turns on SlowAPIMiddleware). Unset
# = only the per-route limits above apply. /health is always exempt.
# RATE_LIMIT_DEFAULT=120/hour

# Rate-limit storage. Default in-process ("memory://", per worker). Point at
# Redis to share buckets across instances when scaling horizontally.
# RATE_LIMIT_STORAGE_URI=memory://

# MMR (Maximal Marginal Relevance) retrieval config
# Number of chunks passed to the LLM (default: 5)
RETRIEVAL_K=5
# Candidate pool MMR selects from; must be >= RETRIEVAL_K (default: 20)
RETRIEVAL_FETCH_K=20
# Relevance/diversity dial: 1.0 = pure relevance, 0.0 = pure diversity (default: 0.5)
RETRIEVAL_LAMBDA_MULT=0.5
# Trailing recency window in days: retrieval only considers articles published in
# the last N days (e.g. 180 for 6 months). 0 disables it (whole corpus). (default: 365)
RETRIEVAL_WINDOW_DAYS=365

# ── Observability — Langfuse (optional) ──────────────────────────────────────
# Leave blank to disable tracing. Sign up at https://langfuse.com/
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── AI Gateway ───────────────────────────────────────────────────────────────
# Controls cost optimisation, caching, and spend limits.
# All keys below are optional — defaults shown are applied if omitted.

# Enable/disable the gateway entirely (default: true)
AI_GATEWAY_ENABLED=true

# Routing strategy: cost_optimized | quality_first | hybrid (default: hybrid)
AI_GATEWAY_STRATEGY=hybrid

# Cache LLM responses to avoid redundant API calls (default: true)
AI_GATEWAY_CACHE_ENABLED=true

# Cache backend:
#   memory   - in-process, cleared on restart/cold start
#   supabase - persists across restarts & shared across instances; requires
#              the llm_cache table (apply sql/llm_cache.sql) and the SUPABASE_*
#              vars above. Recommended for deployed envs; keep memory for
#              local/CI so the cache needs no Supabase.
AI_GATEWAY_CACHE_TYPE=memory

# How long to keep cached responses in seconds (default: 604800 = 7 days)
AI_GATEWAY_CACHE_TTL_SECONDS=604800

# Cache-busting tag folded into every cache key. Leave empty to default to the
# primary model name (switching models busts the cache automatically). Bump
# this after editing a prompt to invalidate a persistent (supabase) cache that a
# redeploy alone would not clear.
AI_GATEWAY_CACHE_VERSION=

# Hard spend limits — app will stop calling the LLM if exceeded
AI_GATEWAY_COST_LIMIT_DAILY=5.0
AI_GATEWAY_COST_LIMIT_MONTHLY=100.0

# Emit per-call cost metrics to logs (default: true)
AI_GATEWAY_TRACK_METRICS=true
