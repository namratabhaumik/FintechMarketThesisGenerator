{
  "name": "finthesis-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Vanilla TS frontend, typed against the FastAPI OpenAPI schema.",
  "scripts": {
    "dump:schema": "uv run --directory .. python scripts/dump_openapi.py",
    "gen:types": "openapi-typescript openapi.json -o src/types.gen.ts",
    "generate": "npm run dump:schema && npm run gen:types",
    "typecheck": "tsc --noEmit",
    "build": "node build.mjs",
    "dev": "npm run build && esbuild src/main.ts --bundle --format=esm --outfile=dist/main.js --servedir=dist --serve=127.0.0.1:3000"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "daisyui": "^5.6.16",
    "esbuild": "^0.21.0",
    "openapi-typescript": "^7.4.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.4.0"
  }
}
