{
  "name": "finthesis-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Vanilla TS frontend, typed against the FastAPI OpenAPI schema.",
  "scripts": {
    "dump:schema": "uv run --directory .. python scripts/dump_openapi.py",
    "gen:types": "openapi-typescript openapi.json -o src/types.gen.ts",
    "generate": "npm run dump:schema && npm run gen:types",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "dev": "vite"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "daisyui": "^5.6.16",
    "openapi-typescript": "^7.4.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.4.0",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  }
}
